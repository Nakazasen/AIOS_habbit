{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIOS Habit Phase Record",
  "type": "object",
  "required": [
    "phase_id",
    "name",
    "objective",
    "scope",
    "deliverables",
    "risk",
    "dependencies",
    "validation",
    "exit_criteria",
    "handover",
    "rollback",
    "status"
  ],
  "properties": {
    "phase_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exit_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handover": {
      "type": "string"
    },
    "rollback": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "open",
        "blocked",
        "pass",
        "fail",
        "rolled_back"
      ]
    }
  }
}
