{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIOS Habit Workflow Card",
  "type": "object",
  "required": [
    "workflow_id",
    "name",
    "trigger",
    "inputs",
    "steps",
    "outputs",
    "validation",
    "rollback",
    "evidence",
    "status"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "pattern": "^WFL-[0-9]{4,}$"
    },
    "name": {
      "type": "string"
    },
    "trigger": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pre_check": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "pass_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fail_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "string"
    },
    "handover": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "candidate",
        "validated",
        "deprecated"
      ]
    }
  }
}
